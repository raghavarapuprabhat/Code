# Copy to .env and fill in real values. .env is gitignored.

# --- LLM ---
ANTHROPIC_API_KEY=sk-ant-...
DEEPSEEK_API_KEY=sk-...
# Optional alternates the LiteLLM adapter can switch to via config.yaml:
# OPENAI_API_KEY=
# AZURE_OPENAI_API_KEY=
# AZURE_OPENAI_API_BASE=
#
# Global LLM override (applies to all agents unless you keep these commented):
# LLM_PROVIDER=anthropic            # or deepseek
# LLM_MODEL=claude-opus-4-7         # deepseek example: deepseek-chat
# LLM_API_KEY_ENV=ANTHROPIC_API_KEY # deepseek example: DEEPSEEK_API_KEY
# LLM_BASE_URL=                     # deepseek: https://api.deepseek.com
#
# Custom OpenAI-compatible endpoint (internal gateway / proxy) with a Bearer token:
# LLM_PROVIDER=custom
# LLM_MODEL=<model name the gateway expects>
# LLM_BASE_URL=https://my-gateway.internal/v1
# LLM_AUTH_TOKEN_ENV=MY_GATEWAY_TOKEN   # name of the env var holding the raw token
# MY_GATEWAY_TOKEN=<the bearer token>   # sent as: Authorization: Bearer <token>
# (For a non-standard header/scheme, set auth_header/auth_scheme/extra_headers in the
#  agent's config.yaml llm block instead — see that file's comments.)

# --- Storage ---
# DEFAULT: zero-config file-based SQLite at Code/aiagent.db (no DATABASE_URL
# needed). The schema is auto-created on backend startup and persists across
# restarts, so you only index a project once.
#
# To use Postgres instead, uncomment DATABASE_URL (SQLAlchemy async / asyncpg).
# If you start from a Prisma URL, keep host/user/pass/db and switch the scheme
# to postgresql+asyncpg. You can also point at a custom SQLite path, e.g.
# DATABASE_URL=sqlite+aiosqlite:////absolute/path/to/aiagent.db
# DATABASE_URL=postgresql+asyncpg://postgres:alekya@localhost:5432/AiAgents
CHROMA_HOST=localhost
CHROMA_PORT=8001
# Or set CHROMA_PATH=./.chroma to use in-process persistent mode (no Docker needed).

# --- Azure DevOps ---
# Required for the SRE Fixer Agent to open PRs against Azure Repos:
# AZURE_DEVOPS_ORG=https://dev.azure.com/<your-org>
# AZURE_DEVOPS_PAT=<PAT with Code R/W and Pull Request R/W>

# Required for the ADO MD/Developer assistants (Phase 4 / 5) and the Code Doc
# Agent's requirements ingest (§8.9.1). The MCP client maps ADO_PAT -> AZURE_DEVOPS_PAT.
# ADO_MCP_COMMAND=npx
# ADO_MCP_ARGS=@azure-devops/mcp
# ADO_PAT=<PAT with Work Items + Code read>

# Required for SRE ADO write-back — auto-filing confirmed bugs as work items (§9.17.7).
# Also flip sre.ado_writeback.enabled: true in agents/sre_agent/config.yaml (off by default).
# ADO_PROJECT=<project name>
# ADO_ORG_URL=https://dev.azure.com/<your-org>
